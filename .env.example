# Application port (default: 3000)
PORT=3000

# CORS allowed origins (comma-separated for multiple)
ALLOWED_ORIGINS=https://your-frontend.com

# Database connection string
DATABASE_URL=postgresql://tracker:tracker123@localhost:5432/tracker

# Database connection pool
DB_POOL_MAX=20
DB_POOL_MIN=5

# JWT configuration
JWT_SECRET=your-secret-key-change-me-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Redis configuration
REDIS_URL=redis://localhost:6379
REDIS_TTL=3600

# API base URL (used for RFC 9457 Problem Details type URI)
API_BASE_URL=https://api.example.com

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
THROTTLE_AUTH_TTL=60000
THROTTLE_AUTH_LIMIT=5

# Google OAuth (optional — omit all three to disable Google login)
# GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=your-google-client-secret
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# GitHub OAuth (optional — omit all three to disable GitHub login)
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# Frontend redirect URL after social auth (required if any social provider is configured)
# SOCIAL_AUTH_REDIRECT_URL=http://localhost:5173/auth/callback

# SMTP configuration for transactional emails (optional — emails are skipped if not configured)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM="Tracker <your-email@gmail.com>"

# Frontend URL to redirect after email verification (verification links use API_BASE_URL)
# EMAIL_VERIFICATION_REDIRECT_URL=http://localhost:5173/onboarding
