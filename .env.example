# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://tracker:tracker123@localhost:5432/tracker
DB_POOL_MAX=20
DB_POOL_MIN=5

# =============================================================================
# Docker Compose (used by docker/docker-compose.yml)
# =============================================================================
POSTGRES_USER=tracker
POSTGRES_PASSWORD=tracker123
POSTGRES_DB=tracker
REDIS_PASSWORD=tracker123

# =============================================================================
# Redis
# =============================================================================
REDIS_URL=redis://:tracker123@localhost:6379
REDIS_TTL=3600

# =============================================================================
# JWT Authentication
# =============================================================================
JWT_SECRET=your-secret-key-must-be-at-least-32-characters
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =============================================================================
# CORS
# =============================================================================
ALLOWED_ORIGINS=http://localhost:5173

# =============================================================================
# Rate Limiting
# =============================================================================
THROTTLE_TTL=60000
THROTTLE_LIMIT=60
THROTTLE_AUTH_TTL=60000
THROTTLE_AUTH_LIMIT=5

# =============================================================================
# Cookies
# =============================================================================
REFRESH_TOKEN_COOKIE_NAME=refresh_token
CSRF_TOKEN_COOKIE_NAME=csrf_token
# COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAME_SITE=strict
COOKIE_PATH=/

# =============================================================================
# Google OAuth (optional - all three required if any is set)
# =============================================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# =============================================================================
# GitHub OAuth (optional - all three required if any is set)
# =============================================================================
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=
# GITHUB_CALLBACK_URL=http://localhost:3000/auth/github/callback

# =============================================================================
# Social Auth (required when any OAuth provider is configured)
# =============================================================================
# SOCIAL_AUTH_REDIRECT_URL=http://localhost:5173/auth/callback

# =============================================================================
# Email / SMTP (optional)
# =============================================================================
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# EMAIL_VERIFICATION_REDIRECT_URL=http://localhost:5173/verify-email
