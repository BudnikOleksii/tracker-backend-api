{
  "name": "tracker-backend-api",
  "version": "0.0.1",
  "private": true,
  "description": "Tracker Backend API - NestJS with Drizzle ORM",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest build && nest start --watch",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "check-types": "tsc -b --noEmit"
  },
  "dependencies": {
    "@keyv/redis": "5.1.6",
    "@nestjs/cache-manager": "3.1.0",
    "@nestjs/common": "11.1.16",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.16",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.16",
    "@nestjs/schedule": "6.1.1",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/terminus": "11.1.1",
    "@scalar/nestjs-api-reference": "1.1.3",
    "bcrypt": "6.0.0",
    "cache-manager": "7.2.8",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "drizzle-orm": "0.45.1",
    "keyv": "5.6.0",
    "nestjs-cls": "6.2.0",
    "nestjs-pino": "4.6.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "pg": "8.20.0",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.16",
    "@swc/cli": "0.8.0",
    "@swc/core": "1.15.18",
    "@types/bcrypt": "6.0.0",
    "@types/express": "5.0.6",
    "@types/node": "25.5.0",
    "@types/passport-jwt": "4.0.1",
    "@types/pg": "8.18.0",
    "dotenv": "17.3.1",
    "drizzle-kit": "0.31.9",
    "pino-pretty": "13.1.3",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "bcrypt",
      "@swc/core"
    ]
  }
}
