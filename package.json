{
  "name": "tracker-backend-api",
  "version": "0.0.1",
  "private": true,
  "description": "Tracker Backend API - NestJS with Drizzle ORM",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "build": "nest build",
    "dev": "nest build && nest start --watch",
    "start": "nest start",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate",
    "db:push": "tsx node_modules/drizzle-kit/bin.cjs push",
    "db:seed": "tsx --env-file=.env src/database/seeds/index.ts",
    "db:studio": "tsx node_modules/drizzle-kit/bin.cjs studio",
    "check-types": "tsc -b --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "dependencies": {
    "@keyv/redis": "5.1.6",
    "@nestjs/cache-manager": "3.1.0",
    "@nestjs/common": "11.1.16",
    "@nestjs/config": "4.0.3",
    "@nestjs/core": "11.1.16",
    "@nestjs/event-emitter": "3.0.1",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.16",
    "@nestjs/schedule": "6.1.1",
    "@nestjs/swagger": "11.2.6",
    "@nestjs/terminus": "11.1.1",
    "@nestjs/throttler": "6.5.0",
    "@scalar/nestjs-api-reference": "1.1.3",
    "bcrypt": "6.0.0",
    "cache-manager": "7.2.8",
    "class-transformer": "0.5.1",
    "class-validator": "0.15.1",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "csv-parse": "6.2.1",
    "csv-stringify": "6.7.0",
    "decimal.js": "10.6.0",
    "drizzle-orm": "0.45.1",
    "helmet": "8.1.0",
    "ioredis": "5.10.0",
    "keyv": "5.6.0",
    "nestjs-cls": "6.2.0",
    "nestjs-pino": "4.6.1",
    "nodemailer": "8.0.5",
    "passport": "0.7.0",
    "passport-github2": "0.1.12",
    "passport-google-oauth20": "2.0.0",
    "passport-jwt": "4.0.1",
    "pg": "8.20.0",
    "pino-http": "11.0.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@commitlint/cli": "20.4.4",
    "@commitlint/config-conventional": "20.4.4",
    "@eslint/js": "10.0.1",
    "@nestjs/cli": "11.0.16",
    "@nestjs/schematics": "11.0.9",
    "@nestjs/testing": "11.1.16",
    "@swc/cli": "0.8.0",
    "@swc/core": "1.15.18",
    "@types/bcrypt": "6.0.0",
    "@types/compression": "1.8.1",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/multer": "2.1.0",
    "@types/node": "25.5.0",
    "@types/nodemailer": "8.0.0",
    "@types/passport-github2": "1.2.9",
    "@types/passport-google-oauth20": "2.0.16",
    "@types/passport-jwt": "4.0.1",
    "@types/pg": "8.18.0",
    "dotenv": "17.3.1",
    "drizzle-kit": "0.31.9",
    "eslint": "10.0.3",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-unused-imports": "4.4.1",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jiti": "2.6.1",
    "lint-staged": "16.4.0",
    "pino-pretty": "13.1.3",
    "prettier": "3.8.1",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.0",
    "vitest": "4.1.0"
  },
  "lint-staged": {
    "*.{ts,mts,cts}": "eslint --fix",
    "*.{ts,mts,cts,json,yml,yaml,md}": "prettier --write"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@nestjs/core",
      "bcrypt",
      "@swc/core"
    ]
  }
}
